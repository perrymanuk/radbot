[flake8]
# Black enforces line-length 88 for code; flake8's 120 catches only the
# pathological cases (accidentally-long lines, copy-pasted long strings).
# Lines >120 that genuinely can't be split (prompt strings, schemas) carry
# an explicit `# noqa: E501` so intent is documented.
max-line-length = 120

# Codes we explicitly ignore project-wide:
#   E203 — whitespace before ':' (conflicts with black)
# Everything else (E402/F401/F541/F811/F824/F841/W293/W605) was previously
# muted here and has been fixed + re-enabled via PT16 steps.
extend-ignore = E203

# Per-file overrides for files where wholesale ignores would hide real bugs.
per-file-ignores =
    # __init__.py files: explicit re-exports
    **/__init__.py:F401
    # Long prompt strings inside triple-quoted blocks where per-line noqa
    # isn't syntactically possible (comment would become part of the string).
    radbot/agent/research_agent/instructions.py:E501
    radbot/tools/alertmanager/processor.py:E501

# Standard exclusions
exclude =
    .git,
    .venv,
    __pycache__,
    build,
    dist,
    node_modules,
    radbot/web/frontend,
    *.egg-info,
    .claude/worktrees,
